# Agrisolar Backend Environment Configuration
# Feature: 001-agrisolar-smart-farming
# Copy this file to .env and fill in your values. NEVER commit .env to version control.

# Database (PostgreSQL)
DATABASE_URL=postgresql://agrisolar:agrisolar_dev@localhost:5432/agrisolar
POSTGRES_USER=agrisolar
POSTGRES_PASSWORD=agrisolar_dev
POSTGRES_DB=agrisolar

# MQTT (Mosquitto)
MQTT_URL=mqtt://localhost:1883

# JWT Authentication
JWT_SECRET=change_this_to_a_secure_random_string
JWT_EXPIRES_IN=24h

# Seed Admin Credentials
SEED_ADMIN_EMAIL=admin@farm.com
SEED_ADMIN_PASSWORD=FarmAdmin2026!
